
#MINERU
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
MODELSCOPE_CACHE=D:/ai_models/modelscope_cache
HF_HOME=D:/ai_models/huggingface_cache
MD_ROOT_DIR=./temp-files/


# api_key申请地址：https://bailian.console.aliyun.com/cn-beijing/?spm=5176.29597918.J_SEsSjsNv72yRuRFS2VknO.2.4d877b08ThdGtP&tab=model#/api-key
# 大模型的文档地址：https://bailian.console.aliyun.com/cn-beijing/?spm=5176.29597918.J_SEsSjsNv72yRuRFS2VknO.2.4d877b08ThdGtP&tab=doc#/doc
# Qwen3系列Flash模型，实现思考模式和非思考模式的有效融合，可在对话中切换模式。复杂推理类任务性能优秀，指令遵循、文本理解等能力显著提高。支持1M上下文长度，按照上下文长度进行阶梯计费。
LLM_DEFAULT_MODEL=qwen-flash
#Qwen3系列小尺寸视觉理解模型，实现思考模式和非思考模式的有效融合，效果优于开源版Qwen3-VL-30B-A3B，响应速度快。全面升级图像/视频理解，支持长视频长文档等超长上下文、
#空间感知与万物识别；具备视觉2D/3D定位能力，胜任复杂现实任务。
VL_MODEL=qwen3-vl-flash
OPENAI_API_KEY=xxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_TEMPERATURE=0.1


# embedding模型！ 进行向量生成！！ 魔搭下载模型到本地！！ (tool文件夹中提供了下载embedding和ranker模型的代码)
BGE_M3_PATH=D:\ai_models\xxx
BGE_M3=BAAI/bge-m3
# gpu
BGE_DEVICE=cuda:0
# cpu 
# BGE_DEVICE=cpu
# cpu 需要关闭 0  GPU 上生成向量通常默认开启了半精度浮点数（FP16）加速，而 CPU 上通常使用单精度（FP32）
BGE_FP16=1
ITEM_NAME_DIAG=1

# Milvus 配置（milvus的Ubuntu中docker部署，在结点5的md文档中有说明）
# 需要先在Ubuntu下载python环境 将centos中的yum指令替换为 apt-get
# docker部署 Milvus 2.4.11 单机版后，因为Milvus采用Minio存储所以自己会下载一个Minio，导致Milvus和Minio端口冲突，所以修改 docker-compose.yml中的端口
# 最后部署 Attu 2.4.0 可视化客户端（适配 Milvus 2.4.11），进行测试使用即可
# 切换成你milvus的url地址
MILVUS_URL=xxxx
# 存储切片集合
CHUNKS_COLLECTION=kb_chunks
# 预留
ENTITY_NAME_COLLECTION=kb_graph_entity_names
# 存储每个文档对应的实体类
ITEM_NAME_COLLECTION=kb_item_names

EMBEDDING_DIM=1536

MILVUS_METRIC_TYPE=COSINE
MILVUS_MIN_COSINE_SCORE=0.75

# Neo4j 配置（如果已启动的话）
NEO4J_URI=bolt://192.168.11.104:7687
NEO4J_DATABASE=neo4j #社区版不支持多数据库
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=123123123

#Mongodb的配置
MONGO_URL=xxxx
MONGO_DB_NAME=kb002

#minio客户端
MINIO_ENDPOINT=xxxx
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# 重排序模型配置(同样去魔塔社区去下载)
# 因为bge-reranker-large支持的输入长度为512，你的输入如果大于512做一下处理策略
# 1. 修改初始每一块的切割长度   2. 模型上下文压缩context_compact  3. 换输入长度更大的版本，如gemma版本的  4. 直接不做处理(因为面对的情景文档长度都不太大，所以我采用这个)
BGE_RERANKER_LARGE=D:\ai_models\xxx
BGE_RERANKER_DEVICE=cuda:0
#BGE_RERANKER_DEVICE=cpu
#BGE_RERANKER_FP16=1
BGE_RERANKER_FP16=0


MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse


# mineru api以及url处理地址！
MINERU_API_TOKEN=xxx
MINERU_BASE_URL=https://mineru.net/api/v4



# ===================== Redis 缓存配置（会话存储 & 会话摘要） =====================
# 功能说明: 存储对话摘要缓存，用于短期记忆快速检索（TTL=24h）
# 当会话超过5轮后自动压缩历史并缓存，下次提问先查缓存减少检索压力
# 参考: 使用 Redis Hash 结构存储 Q&A 摘要，Set 管理会话摘要索引
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# 密码为空则不启用认证，生产环境建议设置
REDIS_PASSWORD=
# 缓存过期时间（秒），默认 24 小时
REDIS_CACHE_TTL=86400
# 缓存相关性判断阈值（BGE-Reranker 交叉编码器评分，0~1）
CACHE_RELEVANCE_THRESHOLD=0.85
# 触发历史压缩的会话轮数阈值（交流大于5轮触发）
COMPACT_TURN_THRESHOLD=5

# ===================== 日志配置 =====================
# 控制台日志：True=开启/False=关闭，级别可选(DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO

# 日志配置
# 文件日志：True=开启/False=关闭，级别与控制台可独立设置
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
# 日志文件保留天数（自动删除过期日志，避免磁盘占满）
LOG_FILE_RETENTION=7 days